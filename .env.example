# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Telegram user_id владельца — единственный, кому шлются заявки и кто может писать боту.
# Узнать ID: напиши боту /start после деплоя — он ответит твоим ID (если переменная пустая).
ALLOWED_TELEGRAM_USER_ID=

# (опционально, обратная совместимость) — если задано, используется как chat_id для рассылки заявок.
# Можно не заполнять, тогда возьмётся ALLOWED_TELEGRAM_USER_ID.
TELEGRAM_CHAT_ID=

# Секрет для верификации webhook от Telegram (любая строка 1–256 символов: A-Z a-z 0-9 _ -).
# Передаётся в setWebhook параметром secret_token и проверяется в заголовке X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET=
